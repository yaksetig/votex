# Public browser configuration. The anon key is intentionally public; access
# is enforced by RLS and controlled edge-function write paths.
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# Optional CDN/storage prefix for immutable circuit artifacts.
VITE_CIRCUIT_FILES_URL=/circuits/

# Edge-function configuration (set through Supabase, never with VITE_):
# FIXED_AUTHORITY_ID=<uuid of the pre-created, real fixed authority row>
# ALLOWED_ORIGIN=https://your-app.example
# RP_SIGNING_KEY=<World ID relying-party signing key>
# WORLD_ID_RP_ID=<World ID relying-party id>
